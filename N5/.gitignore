# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*~

# Python (for the author-side tool scripts)
__pycache__/
*.pyc
.pytest_cache/

# Local-only files
*.local
*.draft
.claude/settings.local.json
.git_commit_msg.txt
# Audio render backups — pre-VOICEVOX gTTS / pre-edge-TTS originals kept
# locally for revert/comparison; not part of the shipped corpus.
audio/_backup_gtts_*/
audio/_backup_*/

# Transient verifier output (regenerated on every audit run; archived copy in not-required/)
/drift_report.txt

# Node / Playwright (introduced for CI smoke; the app stays vanilla static)
node_modules/
playwright-report/
test-results/
.lighthouseci/
# package-lock.json IS committed (removed from gitignore 2026-04-30) — without
# it, `setup-node@v4 cache: 'npm'` in CI fails because the npm-cache step
# requires a lock file, and the playwright-p0-smoke workflow could not run.
audit_out.json

# External-data caches (regenerable from upstream URLs; not committed).
# Path moved out of not-required/ on 2026-05-16 — per hygiene policy,
# anything active code reads must live outside not-required/.
external-data/_cache_*.txt
external-data/_cache_*.json
# Legacy paths retained for one release cycle in case stale local
# checkouts still write to the old location.
not-required/tools-archive/_cache_*.txt
not-required/tools-archive/_cache_*.json

# Local snapshot files (data/*.bak_*, feedback/*.bak_*, etc.) — kept on
# disk for fast local rollback while a wave is in flight; never committed
# (full git history covers every state these snapshots represent). Older
# snapshots archived to not-required/data/ + not-required/feedback/ after
# their parent commit ships (see tools/archive_old_snapshots.py).
# Added 2026-05-13 during snapshot housekeeping (79 older snapshots moved).
**/*.bak
**/*.bak_*
**/*.backup
**/*.backup_*
.commit_msg.tmp

# Test artifacts — PDF printouts of grammar / vocab / kanji pages used
# for visual proofing during native-teacher review. Not source; not
# part of the shipped surface. Added 2026-05-17 (had an untracked
# n5-008.pdf in tests/ from a prior visual-proofing session).
tests/*.pdf
